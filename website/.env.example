# Supabase (required for /api/activate, auth, and other API routes)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: if different from NEXT_PUBLIC_SUPABASE_URL (e.g. server-only)
# SUPABASE_URL=https://your-project.supabase.co

# Optional: public site URL (used for links in emails, etc.)
# NEXT_PUBLIC_APP_URL=https://www.ringtap.me

# Optional: Universal Links / App Links (see docs/UNIVERSAL_LINKS.md)
# APPLE_TEAM_ID=YourAppleTeamID
# ANDROID_SHA256_FINGERPRINTS=AA:BB:CC:... (comma-separated if multiple)

# Optional: Google Search Console verification (see docs/INDEXING.md)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Stripe (Pro plan recurring checkout at /upgrade)
# Get secret key from: Stripe Dashboard → Developers → API keys
# Create a Product "Pro" with recurring Prices: $9/month and (optional) $90/year
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID_YEARLY=price_
# For webhooks: Stripe Dashboard → Developers → Webhooks → Add endpoint
# URL: https://www.ringtap.me/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: for client-side Stripe (e.g. Elements) — use Publishable key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# IAP receipt validation (required for App Store IAP - /api/iap/validate-receipt)
# App Store Connect → Your App → App Information → App-Specific Shared Secret
APPLE_SHARED_SECRET=your-app-specific-shared-secret

# OpenAI - for AI-powered business card parsing (/api/parse-contact)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# HubSpot - for CRM sync (Settings → Integrations, Contacts → Sync to CRM)
# Create app at: https://developers.hubspot.com/ (or developers.hubspot.com for NA2)
# Scopes: crm.objects.contacts.read, crm.objects.contacts.write
#
# CRITICAL: Add the EXACT redirect URI to your HubSpot app or you'll get "This login URL is invalid":
#   - Production: https://www.ringtap.me/api/crm/callback (must match NEXT_PUBLIC_APP_URL)
#   - Local dev:  http://localhost:3000/api/crm/callback
# Legacy apps: IP addresses NOT supported. Use domain or localhost only.
#
# Override auto-detected redirect (if Vercel/preview URL differs from production):
# HUBSPOT_REDIRECT_URI=https://www.ringtap.me/api/crm/callback
#
# For NA2 HubSpot accounts: HUBSPOT_AUTH_URL=https://app-na2.hubspot.com/oauth/authorize
# HUBSPOT_CLIENT_ID=your-client-id
# HUBSPOT_CLIENT_SECRET=your-client-secret
