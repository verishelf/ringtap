# Supabase (project ID: wdffdlznfthxwjhumacs)
# Get anon key from: Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://wdffdlznfthxwjhumacs.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions: set secret on the project so send-contact-push accepts website calls
#   supabase secrets set INTERNAL_PUSH_SECRET=your-long-random-string --project-ref wdffdlznfthxwjhumacs
# Website (Vercel etc.): same value for contact pushes from /api/connect and /api/exchange-contact
# RINGTAP_INTERNAL_PUSH_SECRET=your-long-random-string

# Optional: Calendly (for Schedule button on public profile)
# EXPO_PUBLIC_CALENDLY_CLIENT_ID=...

# Optional: API base for CRM, ring, etc. Default: https://www.ringtap.me
# For local dev with website running: EXPO_PUBLIC_RING_API_BASE=http://localhost:3000
# EXPO_PUBLIC_RING_API_BASE=https://www.ringtap.me

# Support chat: your Supabase auth user id so “Message RingTap” opens a DM with you (Auth → Users).
# EXPO_PUBLIC_SUPPORT_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RevenueCat (required for production). Add to .env for dev; use EAS secrets for production builds.
# Get keys from RevenueCat Dashboard → Project → API Keys
# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx

# Optional: Stripe (for checkout/portal - use backend to create sessions)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# NOT USED: Superwall was removed; app uses expo-in-app-purchases.
# Remove EXPO_PUBLIC_SUPERWALL_IOS and EXPO_PUBLIC_SUPERWALL_ANDROID from .env if present.
